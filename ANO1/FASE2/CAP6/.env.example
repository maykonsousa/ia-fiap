# Copie este arquivo para `.env` e preencha as credenciais.
# O arquivo `.env` e' ignorado pelo git (ver .gitignore na raiz do repo).

# ---------------------------------------------------------------
# Opcao A - Oracle local via Docker (padrao desta entrega)
# ---------------------------------------------------------------
ORACLE_USER=fiap
ORACLE_PASSWORD=fiap123
ORACLE_DSN=localhost:1521/FREEPDB1

# ---------------------------------------------------------------
# Opcao B - Oracle institucional da FIAP
# Descomente as tres linhas abaixo (e comente as de cima) se as
# suas credenciais institucionais estiverem ativas.
# ---------------------------------------------------------------
# ORACLE_USER=rmXXXXXX
# ORACLE_PASSWORD=sua_senha
# ORACLE_DSN=oracle.fiap.com.br:1521/ORCL
